[15.8, "o", "\u001b[38;5;208m⠙\u001b[0m Starting MindOS GUI...\r"]
[16.5, "o", "\u001b[38;5;82m✔\u001b[0m GUI running at \u001b[38;5;39mhttp://localhost:19266\u001b[0m\r\n"]
[17.0, "o", "\r\n"]
[17.3, "o", "\u001b[38;5;82m✔\u001b[0m Browser opened automatically\r\n"]
[17.8, "o", "\r\n"]
[18.0, "o", "\u001b[38;5;208m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m\r\n"]
[18.2, "o", "\r\n"]
[18.4, "o", "  \u001b[1m🧠 MindOS is ready!\u001b[0m\r\n"]
[18.6, "o", "\r\n"]
[18.8, "o", "  \u001b[38;5;245mGUI:\u001b[0m     http://localhost:19266\r\n"]
[19.0, "o", "  \u001b[38;5;245mMind:\u001b[0m    ~/my-mind\r\n"]
[19.2, "o", "  \u001b[38;5;245mMCP:\u001b[0m     stdio + http://localhost:19267\r\n"]
[19.5, "o", "\r\n"]
[19.8, "o", "  \u001b[38;5;245mNext:\u001b[0m    Run \u001b[38;5;208mmindos token\u001b[0m to connect your Agents\r\n"]
[20.0, "o", "\r\n"]
[20.2, "o", "\u001b[38;5;208m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m\r\n"]
