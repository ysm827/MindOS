[22.3, "o", "\r\n"]
[22.8, "o", "\r\n"]
[23.0, "o", "\u001b[38;5;82m✔\u001b[0m MCP config copied to clipboard!\r\n"]
[23.3, "o", "\r\n"]
[23.5, "o", "  Paste into Claude Code / Cursor / OpenClaw settings:\r\n"]
[23.8, "o", "\r\n"]
[24.0, "o", "  \u001b[38;5;245m{\u001b[0m\r\n"]
[24.1, "o", "    \u001b[38;5;39m\"mindos\"\u001b[0m: {\r\n"]
[24.2, "o", "      \u001b[38;5;39m\"command\"\u001b[0m: \u001b[38;5;208m\"npx\"\u001b[0m,\r\n"]
[24.3, "o", "      \u001b[38;5;39m\"args\"\u001b[0m: [\u001b[38;5;208m\"@geminilight/mindos\"\u001b[0m, \u001b[38;5;208m\"mcp\"\u001b[0m]\r\n"]
[24.4, "o", "    }\r\n"]
[24.5, "o", "  \u001b[38;5;245m}\u001b[0m\r\n"]
[25.0, "o", "\r\n"]
[25.3, "o", "  \u001b[38;5;82m→ Your Agent can now read & write your knowledge base\u001b[0m\r\n"]
[25.8, "o", "\r\n"]
