[10.0, "o", "\u001b[38;5;208m🧠 MindOS Onboarding\u001b[0m\r\n"]
[10.2, "o", "\r\n"]
[10.5, "o", "? Choose a template: \u001b[38;5;245m(Use arrow keys)\u001b[0m\r\n"]
