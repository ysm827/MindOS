# Web app port for MindOS UI
MINDOS_WEB_PORT=3000

# Knowledge base root directory (absolute path to your my-mind/ folder)
MIND_ROOT=/path/to/mind_os/my-mind

# AI Provider: "anthropic" (default) or "openai"
AI_PROVIDER=anthropic

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI (if AI_PROVIDER=openai)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
