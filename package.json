{
  "name": "@geminilight/mindos",
  "version": "0.1.1",
  "description": "MindOS — Human-Agent Collaborative Mind System. Local-first knowledge base that syncs your mind to all AI Agents via MCP.",
  "keywords": [
    "mindos",
    "mcp",
    "knowledge-base",
    "ai-agent",
    "local-first",
    "second-brain"
  ],
  "type": "module",
  "license": "MIT",
  "author": "GeminiLight",
  "repository": {
    "type": "git",
    "url": "https://github.com/GeminiLight/MindOS"
  },
  "bin": {
    "mindos": "bin/cli.js"
  },
  "workspaces": [
    "app",
    "mcp"
  ],
  "files": [
    "app/",
    "mcp/",
    "templates/",
    "skills/",
    "bin/",
    "scripts/",
    "assets/",
    "README.md",
    "README_zh.md",
    "LICENSE",
    ".env.local.example",
    "!app/node_modules",
    "!app/.next",
    "!app/.env.local",
    "!app/.claude",
    "!app/__tests__",
    "!app/**/*.bak",
    "!mcp/node_modules",
    "!mcp/dist"
  ],
  "scripts": {
    "setup": "node scripts/setup.js",
    "dev": "mindos dev",
    "build": "mindos build",
    "start": "mindos start",
    "mcp": "mindos mcp",
    "test": "cd app && npx vitest run"
  },
  "engines": {
    "node": ">=18"
  }
}
